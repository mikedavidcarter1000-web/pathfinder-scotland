#!/bin/bash
# Post-commit hook: nudge session-learnings.md capture on session-closing commits

COMMIT_MSG=$(git log -1 --pretty=%B)

# Only nudge on commits that look like session-closing commits
if echo "$COMMIT_MSG" | grep -qE "^session[(:]|^(feat|refactor|chore).*(session|sprint|round)"; then
  # Check if this commit touched docs/session-learnings.md
  if ! git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -q "docs/session-learnings.md"; then
    echo ""
    echo "===================================================================="
    echo "Reminder: this looks like a session-closing commit, but"
    echo "docs/session-learnings.md was not updated in this commit."
    echo ""
    echo "Consider running:"
    echo "  1. Open docs/session-learnings.md"
    echo "  2. Append today's learnings"
    echo "  3. Commit with: git commit -am 'docs: capture session learnings'"
    echo "===================================================================="
    echo ""
  fi
fi

exit 0

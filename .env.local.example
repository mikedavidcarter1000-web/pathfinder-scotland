# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Site URL for auth callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database connection (for migrations/imports)
# Get from Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres

# Stripe (for payments)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard > Products)
NEXT_PUBLIC_STRIPE_STUDENT_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# Resend (transactional email -- contact form, parent links, reminders).
# This API key is also pasted into Supabase Dashboard > Authentication > SMTP
# Settings (username "resend", host smtp.resend.com, port 465) so that
# Supabase Auth confirmation, password reset, and magic link emails route
# through Resend rather than Supabase's default sender.
RESEND_API_KEY=re_...
